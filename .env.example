# Application
APP_NAME=PrepOS AI
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1

# Security
SECRET_KEY=change-me-to-a-64-char-random-string-in-production-please-use-secrets-manager
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Database
DATABASE_URL=postgresql+asyncpg://prepos:prepos@localhost:5432/prepos
DATABASE_ECHO=false
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_ALWAYS_EAGER=false

# Events
EVENT_IDEMPOTENCY_TTL_DAYS=90
OUTBOX_PUBLISH_BATCH_SIZE=100
OUTBOX_STALE_MINUTES=5

# Observability
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
OTEL_ENABLED=false
OTEL_SERVICE_NAME=prepos-api
OTEL_EXPORTER_OTLP_ENDPOINT=

# CORS
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
