# Application
APP_NAME=PrepOS AI
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1

# Security
SECRET_KEY=change-me-to-a-64-char-random-string-in-production-please-use-secrets-manager
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Database
DATABASE_URL=postgresql+asyncpg://prepos:prepos@localhost:5432/prepos
# Optional: used once to enable pgvector when the app user is not a superuser
# DATABASE_SUPERUSER_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/prepos
# POSTGRES_SUPERUSER=postgres
# POSTGRES_SUPERUSER_PASSWORD=
DATABASE_ECHO=false
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_ALWAYS_EAGER=false

# Events
EVENT_IDEMPOTENCY_TTL_DAYS=90
OUTBOX_PUBLISH_BATCH_SIZE=100
OUTBOX_STALE_MINUTES=5

# Observability
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
OTEL_ENABLED=false
OTEL_SERVICE_NAME=prepos-api
OTEL_EXPORTER_OTLP_ENDPOINT=

# CORS
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Knowledge / RAG (P7 S15)
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMS=1536
EMBEDDING_BATCH_SIZE=100
KNOWLEDGE_STORAGE_PATH=data/knowledge
KNOWLEDGE_HYBRID_ALPHA=0.7
KNOWLEDGE_CHUNK_SIZE_TOKENS=600
KNOWLEDGE_CHUNK_OVERLAP_TOKENS=100
KNOWLEDGE_SEARCH_DEFAULT_LIMIT=8
KNOWLEDGE_RRF_K=60
LLM_MODEL=gpt-4o-mini
LLM_MAX_COMPLETION_TOKENS=800
KNOWLEDGE_ASK_PROMPT_CHUNK_MAX=8
KNOWLEDGE_RELEVANCE_MIN_SCORE=0.15
